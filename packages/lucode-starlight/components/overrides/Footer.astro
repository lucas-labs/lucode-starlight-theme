---
import Default from '@astrojs/starlight/components/Footer.astro';
import EditLink from 'virtual:starlight/components/EditLink';
import LastUpdated from 'virtual:starlight/components/LastUpdated';
import Pagination from 'virtual:starlight/components/Pagination';
import config from 'virtual:starlight/user-config';

const {
    pagination,
    editUrl,
    lastUpdated,
    entry: {
        data: { template },
    },
} = Astro.locals.starlightRoute;

const { lastUpdated: showLastUpdated, editLink } = config;
const showEditLink = editLink?.baseUrl ? true : false;

const showFooterInSplash =
    template === 'splash' &&
    !!(editUrl || lastUpdated || pagination.next || pagination.prev || config.credits);
---

{
    showFooterInSplash && (
        <div class="container-wrapper">
            <div class="container">
                <Default />
            </div>
        </div>
    )
}

{!showFooterInSplash && template === 'splash' && <div class="padding-negative" />}

<!-- footer -->
{
    template === 'doc' && (
        <footer>
            {(showEditLink || showLastUpdated) && (
                <div data-slot="doc-footer-meta">
                    <LastUpdated />
                    <EditLink />
                </div>
            )}

            <Pagination />
        </footer>
    )
}

<style>
    .padding-negative {
        margin-bottom: -3vh;
    }

    [data-slot='doc-footer-meta'] {
        display: flex;
        gap: calc(var(--spacing) * 4);
        align-items: center;
        justify-content: end;
        font-size: 0.875em;
        color: var(--muted-foreground);
        margin-top: calc(var(--spacing) * 8);
        opacity: 0.75;
    }
</style>

<style is:global>
    footer.sl-flex {
        border-top: none !important;
        display: flex !important;
    }
</style>
