---
const { toc } = Astro.locals.starlightRoute;
---

{!toc && <slot />}

{
    toc && (
        <main class="container-main" data-slot="docs">
            <div class="main">
                <slot />
            </div>

            <div class="toc">
                <slot name="right-sidebar" />
            </div>
        </main>
    )
}

<style>
    .container-main {
        padding-top: 0.5rem;
        padding-bottom: 1.5rem;
        position: relative;
    }

    @media (min-width: 1024px) {
        .container-main {
            padding-left: 2rem;
        }
    }

    @media (min-width: 1280px) {
        .container-main {
            grid-template-columns: 1fr 240px;
            display: grid;
            gap: 2.5rem;
            padding-top: 2rem;
            padding-bottom: 2rem;
        }
    }

    .main {
        max-width: 40rem;
        min-width: 0;
        width: 100%;
        margin-inline: auto;
        padding-inline: 1rem;
        padding-top: 1rem;
    }

    @media (min-width: 768px) {
        .main {
            padding-inline: 0;
        }
    }

    .toc {
        font-size: 0.875rem;
        line-height: 1.25rem;
        display: none;
    }
    @media (min-width: 1280px) {
        .toc {
            display: block;
        }
    }
</style>
