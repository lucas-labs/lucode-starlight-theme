{
    "name": "lucode-starlight",
    "description": "Lucode's theme for Starlight (the Astro native documentation site generator)",
    "module": "index.ts",
    "type": "module",
    "license": "MIT",
    "workspaces": [
        "packages/*",
        "docs/"
    ],
    "scripts": {
        "docs": "bun run --filter lucode-starlight-docs dev",
        "dev": "bun run --filter lucode-starlight-docs dev",
        "docs:build": "bun run --filter lucode-starlight-docs build"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^8.2.0",
        "astro": "^6.1.9"
    }
}
